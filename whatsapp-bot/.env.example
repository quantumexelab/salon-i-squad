# Meta WhatsApp Cloud API
META_API_TOKEN=your_meta_permanent_access_token
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
WEBHOOK_VERIFY_TOKEN=your_custom_verify_token

# Firebase Admin (service account JSON path relative to this folder or absolute)
FIREBASE_CREDENTIALS_PATH=./serviceAccountKey.json

# Optional
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=true
