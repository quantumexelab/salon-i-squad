rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasUserDoc() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isMaster() {
      return hasUserDoc() && userDoc().role == 'master';
    }

    function isStaff() {
      return hasUserDoc()
        && (userDoc().role == 'admin' || userDoc().role == 'master');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // One-time bootstrap: allow info@quantumexe.com to self-promote to master.
    function canBootstrapMaster(userId) {
      return isOwner(userId)
        && request.auth.token.email == 'info@quantumexe.com'
        && request.resource.data.role == 'master';
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isStaff();

      // First-time self signup as client (or master creating staff profiles)
      allow create: if isOwner(userId)
        || (isMaster() && request.resource.data.role == 'admin');

      // Owners can update their profile but cannot change role — except bootstrap.
      // Master can update any user (including assigning admin).
      allow update: if isMaster()
        || canBootstrapMaster(userId)
        || (isOwner(userId)
          && request.resource.data.role == resource.data.role);

      allow delete: if isMaster();
    }

    match /services/{serviceId} {
      // Public catalog — clients can list services before/after login.
      allow read: if true;
      // Salon owners (admin) and platform master can manage offerings.
      allow create, update, delete: if isStaff();
    }

    match /bookings/{bookingId} {
      function ownsBooking() {
        return isSignedIn()
          && (resource.data.userId == request.auth.uid
            || (request.auth.token.email != null
              && resource.data.customerEmail == request.auth.token.email));
      }

      function ownsBookingAfter() {
        return isSignedIn()
          && (request.resource.data.userId == request.auth.uid
            || (request.auth.token.email != null
              && request.resource.data.customerEmail == request.auth.token.email));
      }

      // Staff see all; owners see own; signed-in clients can read confirmed
      // bookings so the booking calendar can hide taken slots.
      allow read: if isStaff()
        || ownsBooking()
        || (isSignedIn() && resource.data.status == 'confirmed');

      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'confirmed';

      // Staff: full updates. Clients: only their bookings; cannot reassign
      // ownership/price/service; may cancel or reschedule while confirmed.
      allow update: if isStaff()
        || (ownsBooking()
          && ownsBookingAfter()
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.serviceId == resource.data.serviceId
          && request.resource.data.price == resource.data.price
          && request.resource.data.duration == resource.data.duration
          && (request.resource.data.status == 'cancelled'
            || request.resource.data.status == 'confirmed'));

      allow delete: if isMaster();
    }

    match /salonSettings/{docId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // Business hours: public read, staff write.
    // Branding: public read, master write only.
    match /settings/{docId} {
      allow read: if true;
      allow create, update, delete: if docId == 'branding'
        ? isMaster()
        : isStaff();
    }

    // Legacy collection name (kept for compatibility).
    match /dayCloses/{dayCloseId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /closed_days/{dayId} {
      allow read: if true;
      allow create, update, delete: if isStaff();
    }

    match /buffers/{bufferId} {
      allow read: if true;
      allow create, update, delete: if isStaff();
    }
  }
}
